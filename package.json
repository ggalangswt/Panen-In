{
  "name": "panenin-repo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @panenin/mobile-web dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @panenin/mobile-web build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typecheck:web": "pnpm --filter @panenin/mobile-web typecheck",
    "clean:web": "pnpm --filter @panenin/mobile-web clean",
    "format": "turbo run format"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "protobufjs",
      "sharp"
    ]
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
